<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main"
    tools:context=".RideDetailsActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        app:title="Ride Details"
        app:titleTextColor="@color/text_primary"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvYourPostingLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YOUR POSTING"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_card_soft"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvDetailDriverName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginVertical="16dp" />

            <TextView
                android:id="@+id/tvDetailFromTo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="17sp"
                android:textColor="@color/text_primary"
                android:lineSpacingExtra="4dp" />

            <TextView
                android:id="@+id/tvDetailDateTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textSize="17sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvDetailSeats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textSize="17sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Additional Notes"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvDetailNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_input_soft"
                android:padding="12dp" />

            <Button
                android:id="@+id/btnRequestSeat"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Request Seat"
                android:visibility="gone"
                android:layout_marginTop="32dp"
                android:backgroundTint="@color/primary"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/layoutOwnerActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="32dp">

                <Button
                    android:id="@+id/btnViewRequests"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="View Requests"
                    android:layout_marginBottom="12dp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnEditRide"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Edit Ride"
                    android:layout_marginBottom="12dp"
                    android:backgroundTint="@color/secondary"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnDeleteRide"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Delete Ride"
                    android:backgroundTint="@android:color/holo_red_dark"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
